// 示例脚本：添加交互逻辑和API调用示例
document.getElementById('btnUpload').addEventListener('click', function() {
  // TODO: 调用文件输入，上传到后端
  alert('上传影像功能触发');
});
document.getElementById('btnReconstruct').addEventListener('click', function() {
  document.getElementById('statusText').textContent = '开始三维重建...';
  // 模拟调用后端API
  simulateReconstruct();
});

// 模拟重建过程
function simulateReconstruct() {
  let progress = 0;
  const interval = setInterval(() => {
    progress += 10;
    document.getElementById('progressBar').style.width = progress + '%';
    if (progress >= 100) {
      clearInterval(interval);
      document.getElementById('statusText').textContent = '三维重建完成';
      // 更新结果列表示例
      addResultItem('椎管狭窄', '中等', 92);
    }
  }, 300);
}

// 添加分析结果条目到列表
function addResultItem(disease, severity, confidence) {
  const li = document.createElement('li');
  li.className = 'result-item';
  li.innerHTML = `<strong>疾病：</strong>${disease}<br>
                  <strong>严重度：</strong>${severity}<br>
                  <strong>置信度：</strong>${confidence}%`;
  document.getElementById('result-list').appendChild(li);
}

document.getElementById('btnExport').addEventListener('click', function() {
  alert('导出报告功能触发');
});
document.getElementById('btnIntegrate').addEventListener('click', function() {
  alert('集成平台功能触发');
});
